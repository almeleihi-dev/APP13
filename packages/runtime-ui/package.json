{
  "name": "@an-act/runtime-ui",
  "version": "1.0.0",
  "description": "AN ACT runtime UI — component dispatcher and screen renderer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./brand.css": "./dist/react/styles/an-act-brand.css",
    "./production.css": "./dist/react/styles/an-act-production.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/react/styles && cp src/react/styles/an-act-brand.css dist/react/styles/an-act-brand.css && cp src/react/styles/an-act-production.css dist/react/styles/an-act-production.css"
  },
  "dependencies": {
    "@an-act/runtime-core": "file:../runtime-core",
    "@an-act/tokens": "file:../tokens"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5"
  },
  "license": "UNLICENSED",
  "private": true
}
