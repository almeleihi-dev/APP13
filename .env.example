# APP13 Platform Kernel — local development defaults
APP13_ENV=local
APP13_SERVICE_ID=app13-api
APP13_HOST=0.0.0.0
APP13_PORT=3000
APP13_LOG_LEVEL=info
APP13_LOG_PRETTY=true

DATABASE_URL=postgres://app13:app13@localhost:5432/app13
REDIS_URL=redis://localhost:6379

# Object storage (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=app13-evidence
S3_ACCESS_KEY=app13
S3_SECRET_KEY=app13secret
S3_REGION=us-east-1

# Idempotency (P0-S5)
IDEMPOTENCY_TTL_SECONDS=86400

JWT_SECRET=local-dev-secret-change-in-production-min-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_ISSUER=app13
SESSION_COOKIE_NAME=app13_session
SESSION_TTL_SECONDS=604800
REFRESH_TTL_SECONDS=604800
KYC_WEBHOOK_SECRET=local-kyc-webhook-secret
KYC_SANDBOX_BASE_URL=https://sandbox.kyc.app13.local
