{
  "name": "app13",
  "version": "0.1.0",
  "private": true,
  "description": "APP13 Platform Kernel — modular monolith",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx scripts/migrate.ts",
    "lint:imports": "dependency-cruiser src --config .dependency-cruiser.cjs",
    "test": "node --import tsx --test test/b1-kernel.test.ts test/b2-identity.test.ts test/b4-contract.test.ts test/b5-execution.test.ts test/b6-financial-domain.test.ts test/ai1-action-intelligence.test.ts",
    "test:ai1": "node --import tsx --test test/ai1-action-intelligence.test.ts test/ai1-action-intelligence-integration.test.ts",
    "verify:ai1": "npm run test:ai1 && npm run build && npm run lint:imports",
    "test:ai2": "node --import tsx --test test/ai2-requirement-intelligence.test.ts test/ai2-requirement-intelligence-integration.test.ts",
    "verify:ai2": "npm run test:ai2 && npm run build && npm run lint:imports",
    "test:ai3": "node --import tsx --test test/ai3-contract-intelligence.test.ts test/ai3-risk-engine.test.ts test/ai3-escrow-engine.test.ts test/ai3-contract-intelligence-integration.test.ts",
    "verify:ai3": "npm run test:ai3 && npm run build && npm run lint:imports",
    "test:ai4": "node --import tsx --test test/ai4-trust-intelligence.test.ts test/ai4-trust-tier.test.ts test/ai4-trust-penalty.test.ts test/ai4-trust-intelligence-integration.test.ts",
    "verify:ai4": "npm run test:ai4 && npm run build && npm run lint:imports",
    "test:ai5": "node --import tsx --test test/ai5-matching-intelligence.test.ts test/ai5-matching-rules.test.ts test/ai5-matching-intelligence-integration.test.ts",
    "verify:ai5": "npm run test:ai5 && npm run build && npm run lint:imports",
    "test:ai6": "node --import tsx --test test/ai6-pricing-intelligence.test.ts test/ai6-pricing-adjustments.test.ts test/ai6-pricing-intelligence-integration.test.ts",
    "verify:ai6": "npm run test:ai6 && npm run build && npm run lint:imports",
    "test:e2e": "node --import tsx --test test/e2e-intelligence-chain.test.ts",
    "test:ai7": "node --import tsx --test test/ai7-negotiation-intelligence.test.ts test/ai7-negotiation-integration.test.ts",
    "verify:ai7": "npm run test:ai7 && npm run build && npm run lint:imports",
    "test:workflow": "node --import tsx --test test/ai-workflow-intelligence.test.ts test/ai-workflow-integration.test.ts",
    "verify:workflow": "npm run test:workflow && npm run build && npm run lint:imports",
    "test:ai8": "node --import tsx --test test/ai8-provider-intelligence.test.ts test/ai8-provider-risk.test.ts test/ai8-provider-capability.test.ts test/ai8-provider-intelligence-integration.test.ts",
    "verify:ai8": "npm run test:ai8 && npm run build && npm run lint:imports",
    "test:integration": "node --import tsx --test test/b4-contract-integration.test.ts",
    "test:b5": "node --import tsx --test test/b5-execution-integration.test.ts",
    "test:b6": "node --import tsx --test --test-concurrency=1 test/b6-financial-migration.test.ts test/b6-ledger-service-integration.test.ts test/b6-escrow-service-integration.test.ts",
    "verify:b4": "bash scripts/verify-b4-docker.sh",
    "verify:b5": "bash scripts/verify-b5-docker.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@fastify/cookie": "^11.0.2",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "dependency-cruiser": "^16.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
