{
  "name": "app13",
  "version": "0.1.0",
  "private": true,
  "description": "APP13 Platform Kernel — modular monolith",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx scripts/migrate.ts",
    "lint:imports": "dependency-cruiser src --config .dependency-cruiser.cjs",
    "test": "node --import tsx --test test/b1-kernel.test.ts test/b2-identity.test.ts test/b4-contract.test.ts test/b5-execution.test.ts test/b6-financial-domain.test.ts",
    "test:integration": "node --import tsx --test test/b4-contract-integration.test.ts",
    "test:b5": "node --import tsx --test test/b5-execution-integration.test.ts",
    "test:b6": "node --import tsx --test test/b6-financial-migration.test.ts",
    "verify:b4": "bash scripts/verify-b4-docker.sh",
    "verify:b5": "bash scripts/verify-b5-docker.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@fastify/cookie": "^11.0.2",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "dependency-cruiser": "^16.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
